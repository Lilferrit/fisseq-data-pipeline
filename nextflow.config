    // }
    // conda {
    //     process.conda = "path/to/environment.yml"
    // }
    // singularity {
    //     singularity.enabled = true
    //     process.container = "path/to/image.sif"
    // }

    // SGE (Sun Grid Engine) — fill in queue name and adjust resources as needed.
    // Run with: nextflow run fisseq.nf -profile sge --input_dir /path/to/data
    // sge {
    //     process {
    //         executor       = 'sge'
    //         queue          = 'all.q'           // SGE queue name
    //         clusterOptions = '-V'              // forward current environment to each job
    //         cpus           = 4
    //         memory         = '16 GB'
    //         time           = '4h'
    //         beforeScript   = "source /path/to/.venv/bin/activate"
    //     }
    // }
}
