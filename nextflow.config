// nextflow.config — pass with: nextflow run your-org/fisseq-data-pipeline -c your.config -profile fowler_sge ...
//
// beforeScript options (add to the process block):
//   Option A: activate a pre-existing venv (recommended for shared clusters)
//     beforeScript = 'source /path/to/your/venv/bin/activate'
//   Option B: install from GitHub on each run (simpler, slower)
//     beforeScript = 'uv pip install git+https://github.com/your-org/fisseqtools.git@main --system'

params {
    input_dir               = null
    config_dir               = null   // optional: dir of YAML configs; each generates one input/*.parquet via INPUT, merged with pre-staged files
    bc_threshold            = 10
    variant_bc_threshold    = 4
    edit_distance_threshold = 1
    downsample_fraction     = null  // optional float (0,1]: QC_FILTER pseudo-variant downsampling, drawn from post-QC cells; null = disabled
    downsample_seed         = 0     // seed for the deterministic downsample selection
    minimum_correlation     = 0.5
    bvb_min_cells           = 50
    bvb_min_batches         = 2
    ovwt_min_cells          = 100
    downsample_wt           = 5000
    aggregate_downsample_wt = null  // optional float (0,1) or int; null = no WT downsampling in AGGREGATE_HALF/AGGREGATE_FEATURE_TYPE
    feature_types           = ["mean", "median", "MAD", "std", "KS", "QQ", "AUROC"]  // all _AGGREGATORS keys
    bootstrap               = 10
    global                  = true  // run OVWT_GLOBAL, BATCHVSBATCH, and the feature-selection global branch
    feature_selection       = true  // run the feature-selection branch (batchwise + global); if false, skip AGGREGATE_FEATURE_TYPE/GENERATE_SPLIT/AGGREGATE_HALF/CORRELATE_FEATURES/BLOCKLIST/COMBINE_BLOCKLISTS/FINALIZE_FEATURE_SELECT entirely
    workflow                = "fisseq"   // "fisseq" | "ovwt"
}

// New feature-selection processes declare label 'process_low'/'process_medium'
// (nf-core-style) in preparation for a future SGE resource profile via
// withLabel selectors below. No profile currently consumes them, so this is
// inert — no functional change to today's runs.
profiles {
