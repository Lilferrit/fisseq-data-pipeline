// nextflow.config — executor and cluster settings only.
// Environment setup (activating a venv, installing packages) belongs in a user
// config passed via -c your.config. See example.config for guidance.

profiles {
    standard {
        // runs locally using the default local executor
    }

    sge {
        process {
            executor       = 'sge'
            queue          = 'all.q'
            clusterOptions = '-V'
            cpus           = 4
            memory         = '16 GB'
            time           = '4h'
        }
    }
}
